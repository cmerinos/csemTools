csemMF(data = ADD_symptoms[, c("ASSK_1", "ASSK_3", "ASSK_5", "ASSK_7", "ASSK_9", "ASSK_2", "ASSK_4", "ASSK_6", "ASSK_8")],
ci = T,
degree = 3, n.parts = 9, )
