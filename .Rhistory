varL <- df_chi[ok_ci] * varD[ok_ci] / chi_l
varU <- df_chi[ok_ci] * varD[ok_ci] / chi_u
# Pasar a CSEM
CSEM2_L <- pmax(varL / 4, 0)
CSEM2_U <- pmax(varU / 4, 0)
