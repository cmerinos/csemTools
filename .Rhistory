#### Use data 1 ####
library(psych)
# Loading data
data("bfi")
# Choosing variables
data.bfi <- bfi[, c("N1", "N2", "N3", "N4", "N5", "gender", "age")]
# Clean for missing values
data.bfi <- data.bfi[complete.cases(data.bfi), ]
data.bfi[, 1:5]
#### scoreCsem ####
output.boots1 <- csemBoots(data = bfi[,1:5], ci = F,
conf.level = .80,
smooth = F, B = 2000)
output.boots2 <- csemBoots(data = bfi[,1:5], ci = F,
conf.level = .80,
smooth = F,
B = 2000,
full.range = T,
score.range = c(5, 30))
scoreCsem(score.indiv = rowSums(bfi[,1:5]), score.ref = output.boots$CSEM$score, csem = output.boots$CSEM$CSEM)
rm(scoreCsem)
