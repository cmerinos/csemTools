form <- stats::as.formula(
paste("y2_fit ~", paste(colnames(Xmat), collapse = " + "))
)
dat_fit <- cbind(y2_fit = y2_fit, Xmat)
fit_model <- stats::lm(form, data = dat_fit)
# PredicciĂ³n por score total (todos los enteros en el rango observado)
score_seq <- seq(
from = floor(min(total, na.rm = TRUE)),
to   = ceiling(max(total, na.rm = TRUE)),
by   = 1
)
newX <- data.frame(x = score_seq)
if (degree >= 2) {
for (d in 2:degree) {
newX[[paste0("x", d)]] <- score_seq^d
}
}
if (ci) {
# PredicciĂ³n con error estĂ¡ndar sobre CSEM^2
pred <- stats::predict(fit_model, newdata = newX, se.fit = TRUE)
fit_vals <- pred$fit
se_vals  <- pred$se.fit
z <- stats::qnorm(1 - (1 - conf.level) / 2)
var_hat   <- pmax(fit_vals, 0)
var_lwr   <- pmax(fit_vals - z * se_vals, 0)
var_upr   <- pmax(fit_vals + z * se_vals, 0)
CSEM_hat  <- sqrt(var_hat)
CSEM_lwr  <- sqrt(var_lwr)
CSEM_upr  <- sqrt(var_upr)
by_score <- data.frame(
Score  = score_seq,
CSEM   = round(CSEM_hat, digits = digits),
lwr.ci = round(CSEM_lwr, digits = digits),
upp.ci = round(CSEM_upr, digits = digits)
)
} else {
# Solo estimaciĂ³n puntual
var_hat <- pmax(stats::predict(fit_model, newdata = newX), 0)
CSEM_hat <- sqrt(var_hat)
by_score <- data.frame(
Score = score_seq,
CSEM  = round(CSEM_hat, digits = digits)
)
}
# Tabla de parĂ¡metros del polinomio (coef, se, t, p)
sum_fit <- summary(fit_model)
coefs   <- sum_fit$coefficients
params_df <- data.frame(
term    = rownames(coefs),
estimate = coefs[, "Estimate"],
se       = coefs[, "Std. Error"],
t.value  = coefs[, "t value"],
p.value  = coefs[, "Pr(>|t|)"],
row.names = NULL
)
}
# --- 6) Settings y mensaje ---
settings <- list(
n.groups   = n.groups,
bin.width  = bin.width,
smooth     = smooth,
degree     = degree,
ci         = ci,
conf.level = conf.level,
digits     = digits,
grouping   = used_scheme
)
message("Thorndike CSEM computed. Grouping: ", used_scheme,
"; Smoothing: ", if (smooth) paste0("polynomial (degree = ", degree, ")") else "none",
